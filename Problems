    "doctorName": "Dr. Ramesh Iyer",
    "hospital": "Apollo Chennai",
    "scheduledAt": "2026-07-10T10:30:00+05:30",
    "tokenNumber": 3,
    "instructions": "Arrive 15 mins early. Bring previous reports.",
